# --- Temporal cluster ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=repo-steward
TEMPORAL_TLS=false

# --- Worker tuning ---
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=4
TEMPORAL_MAX_CONCURRENT_WORKFLOWS=20

# --- GitHub auth ---
# Personal Access Token used by `gh` and `git push`.
# Required scopes — see README "GitHub PAT に必要な権限".
#   classic PAT: repo, workflow
#   fine-grained PAT (single repo):
#     - Contents:        Read & Write   (clone, push)
#     - Pull requests:   Read & Write   (PR create / merge)
#     - Actions:         Read           (gh run view --log-failed)
#     - Workflows:       Read & Write   (changes that touch .github/workflows)
#     - Metadata:        Read           (auto-included)
GITHUB_TOKEN=ghp_replace_me

# --- Commit identity ---
# Identity stamped on every auto-generated commit. Defaults to a generic
# bot persona; override so commits attribute to a known account.
# Tip: GitHub no-reply emails follow `<id>+<username>@users.noreply.github.com`
# (find yours at https://github.com/settings/emails after enabling
# "Keep my email addresses private").
# GIT_BOT_NAME=my-bot
# GIT_BOT_EMAIL=12345678+myid@users.noreply.github.com

# --- Codex (OpenAI) ---
# Codex CLI reads ~/.codex/auth.json (created by `codex login` in a browser).
# Override the directory with CODEX_HOME if you mount the file elsewhere.
# CODEX_HOME=/var/run/secrets/codex

# --- Advisor (上位モデル相談) ---
# consultAdvisorActivity が `codex exec --model <ADVISOR_MODEL>` で呼び出すモデル名。
# 未設定なら codex のデフォルトモデルが使われる。Advisor は事前集約済みのサマリー
# (≤ 2 KiB) のみを渡し、`{verdict, rationale}` を返す薄いラッパーで、`maxAdvisorConsults`
# （既定 2）でワークフロー単位のハードキャップが効く。
# ADVISOR_MODEL=gpt-5
