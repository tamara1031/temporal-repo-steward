# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TLS=false

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Personal or fine-grained token.
# Required scopes: repo (read+write), workflow, pull_requests, actions (read).
GITHUB_TOKEN=ghp_replace_me

# ── Commit identity ────────────────────────────────────────────────────────────
GIT_BOT_NAME=repo-steward-bot
GIT_BOT_EMAIL=repo-steward-bot@users.noreply.github.com

# ── Codex CLI ──────────────────────────────────────────────────────────────────
# Path to the codex binary (default: "codex", must be on PATH).
# CODEX_BIN=codex
# Optional model override.
# CODEX_MODEL=gpt-4.1

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_ROOT=/workspaces

# ── Schedule (only used when REGISTER_SCHEDULE=true) ──────────────────────────
REGISTER_SCHEDULE=false
TARGET_REPO=owner/repo
BASE_BRANCH=main
REFACTOR_BRIEF=Improve test coverage and remove dead code.
AUTO_MERGE=false
PR_TITLE=chore: automated refactor
PR_BODY=Automated refactoring pass by repo-steward.
SCHEDULE_CRON=0 3 * * 1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
