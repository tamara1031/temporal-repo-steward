{
  "name": "temporal-repo-steward",
  "version": "0.1.0",
  "private": true,
  "description": "Pull-based autonomous AI repo steward built on Temporal",
  "main": "dist/worker.js",
  "scripts": {
    "build": "tsc && npm run build:workflows",
    "build:workflows": "ts-node scripts/build-workflow-bundle.ts",
    "start.worker": "node dist/worker.js",
    "start.worker.dev": "ts-node src/worker.ts",
    "start.client": "ts-node src/client.ts",
    "lint": "tsc --noEmit",
    "lint.tests": "tsc --noEmit -p tsconfig.tests.json",
    "test": "vitest run",
    "test.watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@temporalio/activity": "~1.11.8",
    "@temporalio/client": "~1.11.8",
    "@temporalio/common": "~1.11.8",
    "@temporalio/worker": "~1.11.8",
    "@temporalio/workflow": "~1.11.8",
    "dotenv": "^16.4.5",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@temporalio/testing": "~1.11.8",
    "@types/ms": "^0.7.34",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
